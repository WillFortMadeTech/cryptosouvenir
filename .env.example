# Grid resolution — total columns at the equator.
# Columns per latitude row scale with cos(lat) to keep cube spacing even across the globe.
NEXT_PUBLIC_GRID_ROWS=400
NEXT_PUBLIC_GRID_COLS=800

# Size of each land cube (Three.js units)
NEXT_PUBLIC_CUBE_SIZE=0.01

# Base colour of cubes as a hex literal
NEXT_PUBLIC_CUBE_COLOR=0xffffff

# Shade the hemisphere facing the camera in blue (true/false)
NEXT_PUBLIC_SHOW_HEMISPHERE_COLORS=false
