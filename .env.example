# Grid resolution — total columns at the equator.
# Columns per latitude row scale with cos(lat) to keep cube spacing even across the globe.
NEXT_PUBLIC_GRID_ROWS=400
NEXT_PUBLIC_GRID_COLS=800

# Size of each land cube (Three.js units)
NEXT_PUBLIC_CUBE_SIZE=0.01

# Base colour of cubes as a hex literal
NEXT_PUBLIC_CUBE_COLOR=0xffffff

# Shade the hemisphere facing the camera in blue (true/false)
NEXT_PUBLIC_SHOW_HEMISPHERE_COLORS=false

# LocalStack / AWS — these defaults match LocalStack's built-in test credentials.
# For production, replace with real AWS credentials and remove AWS_ENDPOINT_URL.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
S3_BUCKET=cryptosouvenir-uploads
DYNAMODB_TABLE=cryptosouvenir-submissions
DYNAMODB_CUBES_TABLE=cryptosouvenir-cubes
# Secret used to sign/verify cube claim tokens — change this in production
CLAIM_SECRET=dev-secret-change-me
